[include]
  path = ~/.config/delta/catppuccin-mocha.gitconfig

[alias]
  up = fetch -p
  last = log -1 HEAD --stat --graph
  r = remote -v
  b = branch -a
  c = commit -m
  s = status -sb
  d = diff
  p = pull
  P = push
  stat = status
  ls = log --oneline --decorate --graph
  sub = submodule update --recursive --remote
  conf = config --list --show-origin --show-scope
  aliases = config --get-regex ^alias

[init]
  defaultBranch = master

[core]
  autocrlf = false
  filemode = false
  ignorecase = false
  sshCommand = C:/Windows/System32/OpenSSH/ssh.exe
  pager = delta

[delta]
  features = catppuccin-mocha
  side-by-side = true
  navigate = true

[merge]
  conflictstyle = diff3

[gpg "ssh"]
  program = C:/Windows/System32/OpenSSH/ssh-keygen.exe

[diff]
  colorMoved = default

[http]
  postBuffer = 524288000
  maxRequestBuffer = 524288000

[includeIf "hasconfig:remote.*.url:git@github.com:*/**"]
  path = github.gitconfig

[includeIf "hasconfig:remote.*.url:git@gitlab.vsb.cz:*/**"]
  path = gitlabvsb.gitconfig

[includeIf "hasconfig:remote.*.url:git@ntblppjavorsky:*/**"]
  path = work.gitconfig
